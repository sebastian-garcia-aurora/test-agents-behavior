{
	"name": "test-agents-behavior",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"better-auth": "1.5.2",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @test-agents-behavior/db db:push",
		"db:studio": "turbo -F @test-agents-behavior/db db:studio",
		"db:generate": "turbo -F @test-agents-behavior/db db:generate",
		"db:migrate": "turbo -F @test-agents-behavior/db db:migrate",
		"db:start": "turbo -F @test-agents-behavior/db db:start",
		"db:watch": "turbo -F @test-agents-behavior/db db:watch",
		"db:stop": "turbo -F @test-agents-behavior/db db:stop",
		"db:down": "turbo -F @test-agents-behavior/db db:down",
		"check": "biome check --write .",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@test-agents-behavior/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@test-agents-behavior/config": "workspace:*",
		"@types/bun": "catalog:",
		"lefthook": "^1.11.13",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "bun@1.3.6"
}
